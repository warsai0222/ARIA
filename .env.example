# LLM providers
GROQ_API_KEY=your_groq_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Embeddings (text-embedding-004)
GOOGLE_API_KEY=your_google_api_key_here

# Qdrant Cloud — create free cluster at cloud.qdrant.io
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# Neon PostgreSQL — optional, for query analytics
DATABASE_URL=postgresql://user:password@host/dbname

# Security — comma-separated allowed origins (e.g. your portfolio domain)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500

# Weekly email report (Gmail SMTP)
# 1. Enable 2FA on your Google account
# 2. Go to Google Account → Security → App Passwords → generate a 16-char password
GMAIL_USER=your.gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
REPORT_RECIPIENT=varshith.tipirneni@gmail.com

# HuggingFace deployment (set as GitHub secret, not in this file)
# HF_TOKEN=hf_...
# HF_SPACE_REPO=https://huggingface.co/spaces/YOUR_HF_USERNAME/aria
